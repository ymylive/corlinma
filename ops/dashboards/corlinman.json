    {
      "id": 11,
      "type": "timeseries",
      "title": "Telegram updates/min (by chat_type + mention_reason)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "unit": "opm",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
