        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.5, sum by(le, tool) (rate(corlinman_wstool_invoke_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tool}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by(le, tool) (rate(corlinman_wstool_invoke_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{tool}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by(le, tool) (rate(corlinman_wstool_invoke_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tool}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "FileFetcher throughput (bytes/s, stacked by scheme)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20,
            "stacking": { "mode": "normal" },
